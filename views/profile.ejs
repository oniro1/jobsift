<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>

<%- include('partials/nav') %>

<div class="profile-layout">

  <!-- LEFT: Profile card -->
  <div class="profile-left-col">
    <div class="profile-card">
      <div class="profile-banner"></div>
      <div class="profile-body">
        <div class="profile-avatar-wrap" id="profile-avatar-wrap">
          <div class="profile-avatar <%= (profileUser.profile && profileUser.profile.avatar) ? 'has-image' : '' %>" id="profile-avatar">
            <% if (profileUser.profile && profileUser.profile.avatar) { %>
              <img src="<%= profileUser.profile.avatar %>" alt="<%= profileUser.name %>">
            <% } else { %>
              <%= profileUser.name.split(' ').map(function(n){ return n[0]; }).join('').toUpperCase().slice(0,2) %>
            <% } %>
          </div>
          <% if (isOwnProfile) { %>
          <label class="avatar-change-btn" for="avatar-file-input" title="Change photo">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </label>
          <input type="file" id="avatar-file-input" accept="image/*" style="display:none">
          <% } %>
        </div>
        <div class="profile-name"><%= profileUser.name %></div>
        <div class="profile-headline" id="prof-headline"><%= (profileUser.profile && profileUser.profile.headline) || '' %></div>
        <% if (profileUser.profile && profileUser.profile.location) { %>
        <div class="profile-location">
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
          <span id="prof-location"><%= profileUser.profile.location %></span>
        </div>
        <% } %>
        <div class="profile-stats">
          <div class="profile-stat"><strong id="stat-connections">—</strong><span>connections</span></div>
          <div class="profile-stat"><strong id="stat-posts">—</strong><span>posts</span></div>
        </div>
        <div class="profile-actions">
          <% if (isOwnProfile) { %>
          <button class="btn btn-outline-accent btn-sm" id="edit-profile-btn">Edit profile</button>
          <% } else { %>
          <button class="btn btn-primary btn-sm" id="connect-btn" data-uid="<%= profileUser.id %>">+ Connect</button>
          <button class="btn btn-outline-accent btn-sm" id="message-btn" data-uid="<%= profileUser.id %>" data-name="<%= profileUser.name %>">Message</button>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT: sections -->
  <div class="profile-right-col">

    <!-- About -->
    <div class="profile-section">
      <div class="profile-section-header">
        <div class="profile-section-title">About</div>
        <% if (isOwnProfile) { %>
        <button class="section-edit-btn" id="edit-profile-btn-2" title="Edit">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </button>
        <% } %>
      </div>
      <div id="about-view">
        <div class="profile-bio" id="prof-bio">
          <%= (profileUser.profile && profileUser.profile.bio) ? profileUser.profile.bio : (isOwnProfile ? 'Add a short bio to let people know more about you.' : 'No bio yet.') %>
        </div>
      </div>
      <% if (isOwnProfile) { %>
      <div class="edit-form" id="edit-form">
        <div class="form-group">
          <label class="form-label">Headline</label>
          <input class="form-input" type="text" id="edit-headline" value="<%= (profileUser.profile && profileUser.profile.headline) || '' %>" placeholder="e.g. Full-stack developer at Acme">
        </div>
        <div class="form-group">
          <label class="form-label">Location</label>
          <input class="form-input" type="text" id="edit-location" value="<%= (profileUser.profile && profileUser.profile.location) || '' %>" placeholder="e.g. London, UK">
        </div>
        <div class="form-group">
          <label class="form-label">About</label>
          <textarea class="form-input" id="edit-bio" rows="4" placeholder="Tell people about yourself…"><%= (profileUser.profile && profileUser.profile.bio) || '' %></textarea>
        </div>
        <div class="form-error" id="edit-error"></div>
        <div class="edit-actions">
          <button class="btn btn-ghost btn-sm" id="edit-cancel-btn">Cancel</button>
          <button class="btn btn-primary btn-sm" id="edit-save-btn">Save</button>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Experience -->
    <div class="profile-section">
      <div class="profile-section-header">
        <div class="profile-section-title">Experience</div>
        <% if (isOwnProfile) { %>
        <button class="section-add-btn" id="add-exp-btn" title="Add experience">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <% } %>
      </div>

      <% if (isOwnProfile) { %>
      <div class="section-form" id="exp-form">
        <input type="hidden" id="exp-editing-id">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Title *</label>
            <input class="form-input" type="text" id="exp-title" placeholder="e.g. Software Engineer">
          </div>
          <div class="form-group">
            <label class="form-label">Company *</label>
            <input class="form-input" type="text" id="exp-company" placeholder="e.g. Google">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Start date</label>
            <input class="form-input" type="month" id="exp-start">
          </div>
          <div class="form-group">
            <label class="form-label">End date</label>
            <input class="form-input" type="month" id="exp-end">
            <label style="margin-top:6px;font-size:13px;display:flex;align-items:center;gap:6px;cursor:pointer">
              <input type="checkbox" id="exp-current"> Currently working here
            </label>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Location</label>
          <input class="form-input" type="text" id="exp-location" placeholder="e.g. London, UK">
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea class="form-input" id="exp-description" rows="3" placeholder="Describe your role…"></textarea>
        </div>
        <div class="form-error" id="exp-error"></div>
        <div class="edit-actions">
          <button class="btn btn-ghost btn-sm" id="exp-cancel">Cancel</button>
          <button class="btn btn-primary btn-sm" id="exp-save">Save</button>
        </div>
      </div>
      <% } %>

      <div id="experience-list">
        <% if (profileUser.experience && profileUser.experience.length > 0) { %>
          <% profileUser.experience.forEach(function(exp) { %>
          <div class="timeline-item" data-id="<%= exp._id %>">
            <div class="timeline-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            </div>
            <div class="timeline-body">
              <div class="timeline-title"><%= exp.title %></div>
              <div class="timeline-sub"><%= exp.company %><% if (exp.location) { %> · <%= exp.location %><% } %></div>
              <% if (exp.startDate || exp.endDate || exp.current) { %>
              <div class="timeline-date"><%= exp.startDate || '' %> – <%= exp.current ? 'Present' : (exp.endDate || '') %></div>
              <% } %>
              <% if (exp.description) { %><div class="timeline-desc"><%= exp.description %></div><% } %>
              <% if (isOwnProfile) { %>
              <div class="item-actions">
                <button class="item-btn" data-id="<%= exp._id %>" data-type="experience" onclick="editExperience(this.dataset.id)">Edit</button>
                <button class="item-btn item-btn-del" data-id="<%= exp._id %>" onclick="deleteItem('experience', this.dataset.id, this.closest('.timeline-item'))">Delete</button>
              </div>
              <% } %>
            </div>
          </div>
          <% }) %>
        <% } else { %>
        <div class="section-empty" id="exp-empty"><% if (isOwnProfile) { %>Add your work experience<% } else { %>No experience listed.<% } %></div>
        <% } %>
      </div>
    </div>

    <!-- Education -->
    <div class="profile-section">
      <div class="profile-section-header">
        <div class="profile-section-title">Education</div>
        <% if (isOwnProfile) { %>
        <button class="section-add-btn" id="add-edu-btn" title="Add education">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <% } %>
      </div>

      <% if (isOwnProfile) { %>
      <div class="section-form" id="edu-form">
        <input type="hidden" id="edu-editing-id">
        <div class="form-group">
          <label class="form-label">School *</label>
          <input class="form-input" type="text" id="edu-school" placeholder="e.g. University of Milan">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Degree</label>
            <input class="form-input" type="text" id="edu-degree" placeholder="e.g. Bachelor of Science">
          </div>
          <div class="form-group">
            <label class="form-label">Field of study</label>
            <input class="form-input" type="text" id="edu-field" placeholder="e.g. Computer Science">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Start year</label>
            <input class="form-input" type="number" id="edu-start" placeholder="2018" min="1950" max="2040">
          </div>
          <div class="form-group">
            <label class="form-label">End year</label>
            <input class="form-input" type="number" id="edu-end" placeholder="2022" min="1950" max="2040">
          </div>
        </div>
        <div class="form-error" id="edu-error"></div>
        <div class="edit-actions">
          <button class="btn btn-ghost btn-sm" id="edu-cancel">Cancel</button>
          <button class="btn btn-primary btn-sm" id="edu-save">Save</button>
        </div>
      </div>
      <% } %>

      <div id="education-list">
        <% if (profileUser.education && profileUser.education.length > 0) { %>
          <% profileUser.education.forEach(function(edu) { %>
          <div class="timeline-item" data-id="<%= edu._id %>">
            <div class="timeline-icon">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            </div>
            <div class="timeline-body">
              <div class="timeline-title"><%= edu.school %></div>
              <div class="timeline-sub">
                <%= edu.degree || '' %><% if (edu.degree && edu.field) { %>, <% } %><%= edu.field || '' %>
              </div>
              <% if (edu.startYear || edu.endYear) { %>
              <div class="timeline-date"><%= edu.startYear || '' %> – <%= edu.endYear || 'Present' %></div>
              <% } %>
              <% if (isOwnProfile) { %>
              <div class="item-actions">
                <button class="item-btn" data-id="<%= edu._id %>" onclick="editEducation(this.dataset.id)">Edit</button>
                <button class="item-btn item-btn-del" data-id="<%= edu._id %>" onclick="deleteItem('education', this.dataset.id, this.closest('.timeline-item'))">Delete</button>
              </div>
              <% } %>
            </div>
          </div>
          <% }) %>
        <% } else { %>
        <div class="section-empty" id="edu-empty"><% if (isOwnProfile) { %>Add your education<% } else { %>No education listed.<% } %></div>
        <% } %>
      </div>
    </div>

    <!-- Skills -->
    <div class="profile-section">
      <div class="profile-section-header">
        <div class="profile-section-title">Skills</div>
        <% if (isOwnProfile) { %>
        <button class="section-edit-btn" id="edit-skills-btn" title="Edit skills">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </button>
        <% } %>
      </div>
      <% if (isOwnProfile) { %>
      <div class="section-form" id="skills-form">
        <div class="form-group">
          <label class="form-label">Skills (comma separated)</label>
          <input class="form-input" type="text" id="skills-input"
            value="<%= (profileUser.profile && profileUser.profile.skills) ? profileUser.profile.skills.join(', ') : '' %>"
            placeholder="JavaScript, React, Node.js, SQL…">
        </div>
        <div class="form-error" id="skills-error"></div>
        <div class="edit-actions">
          <button class="btn btn-ghost btn-sm" id="skills-cancel">Cancel</button>
          <button class="btn btn-primary btn-sm" id="skills-save">Save</button>
        </div>
      </div>
      <% } %>
      <div id="skills-list">
        <% if (profileUser.profile && profileUser.profile.skills && profileUser.profile.skills.length > 0) { %>
        <div class="skills-grid">
          <% profileUser.profile.skills.forEach(function(skill) { %>
          <span class="skill-tag"><%= skill %></span>
          <% }) %>
        </div>
        <% } else { %>
        <div class="section-empty"><% if (isOwnProfile) { %>Add your top skills<% } else { %>No skills listed.<% } %></div>
        <% } %>
      </div>
    </div>

    <!-- Posts -->
    <div class="profile-section">
      <div class="profile-section-title">Posts</div>
      <div id="profile-posts">
        <div style="text-align:center;padding:32px;color:var(--ink-3);font-size:14px">Loading…</div>
      </div>
    </div>

  </div>
</div>

<!-- Avatar lightbox -->
<div id="avatar-lightbox">
  <div id="avatar-lightbox-backdrop"></div>
  <div id="avatar-lightbox-body">
    <div id="avatar-lightbox-inner"></div>
    <div id="avatar-lightbox-name"><%= profileUser.name %></div>
  </div>
  <button id="avatar-lightbox-close" aria-label="Close">&times;</button>
</div>

<%- include('partials/footer') %>

<script>
  window.CURRENT_USER   = <%- JSON.stringify(user) %>;
  window.PROFILE_USER   = <%- JSON.stringify(profileUser) %>;
  window.IS_OWN_PROFILE = <%= isOwnProfile %>;
</script>
<script src="/js/profile.js"></script>
</body>
</html>
